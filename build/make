#!/bin/sh
# =============================================================
#  virt-forge — build script
#  Usage: ./build/make [target] [--onefile]
#  Targets: all (default), qemu-run, qemu-ctl, qemu-disk, gui, clean
#
#  --onefile   Build GUI as a single portable binary
#              (only applies to "all" and "gui" targets)
# =============================================================
set -eu

# ── Paths ─────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"
ASSETS="$ROOT/assets"
BIN="$ROOT/bin"

# ── Parse arguments ───────────────────────────────────────────
TARGET=""
GUI_MODE=""

for arg in "$@"; do
    case "$arg" in
        --onefile) GUI_MODE="--onefile" ;;
        --onedir)  GUI_MODE="--onedir"  ;;
        --help|-h)
            printf 'Usage: %s [target] [--onedir|--onefile]\n' "$0"
            printf '\n'
            printf 'Targets:\n'
            printf '  all        Build all Go binaries + GUI (default)\n'
            printf '  qemu-run   Build VM launcher binary only\n'
            printf '  qemu-ctl   Build control binary only\n'
            printf '  qemu-disk  Build disk manager binary only\n'
            printf '  gui        Build GUI only\n'
            printf '  clean      Remove all build output\n'
            printf '\n'
            printf 'Options:\n'
            printf '  --onedir    GUI: one-dir build, _internal/ beside binary (default)\n'
            printf '  --onefile   GUI: single portable binary, no _internal/ needed\n'
            exit 0
            ;;
        -*)
            printf '❌ Unknown option: %s\n' "$arg"
            printf '   Run with --help for usage.\n'
            exit 1
            ;;
        *)
            if [ -z "$TARGET" ]; then
                TARGET="$arg"
            else
                printf '❌ Unexpected argument: %s\n' "$arg"
                exit 1
            fi
            ;;
    esac
done

TARGET="${TARGET:-all}"

# ── Helpers ───────────────────────────────────────────────────
build_go() {
    NAME="$1"
    SOURCE="./$2"
    OUTPUT="$BIN/$NAME"

    printf '🔨 Building %s...\n' "$NAME"
    ( cd "$ASSETS" && CGO_ENABLED=0 go build -ldflags="-s -w" -o "$OUTPUT" "$SOURCE" )
    chmod +x "$OUTPUT"
    printf '✅ %s → bin/%s\n\n' "$NAME" "$NAME"
}

build_gui() {
    if [ -n "$GUI_MODE" ]; then
        sh "$SCRIPT_DIR/make-gui" "$GUI_MODE"
    else
        sh "$SCRIPT_DIR/make-gui"
    fi
}

clean() {
    printf '🧹 Cleaning bin/...\n'
    rm -f  "$BIN/qemu-run" "$BIN/qemu-ctl" "$BIN/qemu-disk"
    rm -f  "$ROOT/virt-forge"
    rm -rf "$ROOT/_internal"
    rm -rf "$SCRIPT_DIR/gui-work" "$SCRIPT_DIR/gui-dist"
    printf '✅ Done\n'
}

# ── Go: clean cache, reset module, tidy, then build ───────────
init_go() {
    check_go
    printf '🧹 Cleaning Go cache...\n'
    go clean -cache -modcache 2>/dev/null || true

    printf '🗑  Removing old go.mod and go.sum...\n'
    rm -f "$ASSETS/go.mod" "$ASSETS/go.sum"

    # Detect module name from existing go.mod if possible,
    # otherwise use a safe default.
    MODULE="github.com/dev-boffin-io/virt-forge"
    printf 'ℹ  Module: %s\n' "$MODULE"

    printf '🔧 Running go mod init...\n'
    ( cd "$ASSETS" && go mod init "$MODULE" )

    printf '🔧 Running go mod tidy...\n'
    ( cd "$ASSETS" && go mod tidy )

    printf '✅ Go module initialised\n\n'
}

# ── Check go availability ────────────────────────────────────
check_go() {
    if ! command -v go > /dev/null 2>&1; then
        printf '❌ Go not found in PATH.\n'
        printf '   Install using your package manager:\n'
        printf '     apt:     sudo apt install golang-go\n'
        printf '     dnf:     sudo dnf install golang\n'
        printf '     pacman:  sudo pacman -S go\n'
        printf '     apk:     sudo apk add go\n'
        printf '   Or run:  sudo ./installer/install-deps.sh build-deps\n'
        exit 1
    fi
    printf 'ℹ  Go: %s\n' "$(go version)"
}

# ── Ensure bin/ exists ────────────────────────────────────────
mkdir -p "$BIN"

# ── Dispatch ──────────────────────────────────────────────────
case "$TARGET" in
    all)
        init_go
        build_go qemu-run      main.go
        build_go qemu-ctl  qemu-ctl.go
        build_go qemu-disk qemu-disk.go
        build_gui
        printf '🎉 All binaries built in bin/\n'
        ;;
    qemu-run)
        init_go
        build_go qemu-run main.go
        ;;
    qemu-ctl)
        init_go
        build_go qemu-ctl qemu-ctl.go
        ;;
    qemu-disk)
        init_go
        build_go qemu-disk qemu-disk.go
        ;;
    gui)
        build_gui
        ;;
    clean)
        clean
        ;;
    *)
        printf '❌ Unknown target: %s\n' "$TARGET"
        printf '   Run with --help for usage.\n'
        exit 1
        ;;
esac
