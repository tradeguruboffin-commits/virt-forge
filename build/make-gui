#!/bin/sh
# =============================================================
#  virt-forge — GUI build script (PyInstaller)
#  Called by: ./build/make gui
#
#  Modes:
#    ./build/make-gui              one-dir  (default)
#    ./build/make-gui --onefile    single portable binary
#
#  Creates a temporary .venv in the project root, installs
#  PyInstaller + PyQt6, builds the GUI, then removes .venv.
#
#  one-dir output:
#    virt-forge        ← executable
#    _internal/        ← PyQt6 + libs (must stay beside binary)
#
#  onefile output:
#    virt-forge        ← single self-contained binary
# =============================================================
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"
GUI_SRC="$ROOT/gui/virt-forge.py"
VENV="$ROOT/.venv"

# ── Parse arguments ───────────────────────────────────────────
MODE="onedir"
for arg in "$@"; do
    case "$arg" in
        --onefile) MODE="onefile" ;;
        --onedir)  MODE="onedir"  ;;
        --help|-h)
            printf 'Usage: %s [--onedir|--onefile]\n' "$0"
            printf '\n'
            printf '  --onedir    One-dir build (default) — faster startup,\n'
            printf '              _internal/ must stay beside the binary.\n'
            printf '  --onefile   Single portable binary — slower startup,\n'
            printf '              no _internal/ needed, easier to distribute.\n'
            exit 0
            ;;
        *)
            printf '❌ Unknown argument: %s\n' "$arg"
            printf '   Run with --help for usage.\n'
            exit 1
            ;;
    esac
done

# ── Detect python3 or python ──────────────────────────────────
PYTHON_BIN=""
for candidate in python3 python; do
    if command -v "$candidate" > /dev/null 2>&1; then
        # Must be Python 3.x
        ver="$("$candidate" -c 'import sys; print(sys.version_info.major)' 2>/dev/null || echo 0)"
        if [ "$ver" = "3" ]; then
            PYTHON_BIN="$candidate"
            break
        fi
    fi
done

if [ -z "$PYTHON_BIN" ]; then
    printf '❌ Python 3 not found in PATH.\n'
    printf '   Install with: sudo apt install python3\n'
    exit 1
fi
printf 'ℹ  Python: %s (%s)\n' "$PYTHON_BIN" "$("$PYTHON_BIN" --version 2>&1)"

# ── Check venv module availability ────────────────────────────
if ! "$PYTHON_BIN" -m venv --help > /dev/null 2>&1; then
    printf '❌ Python venv module not found.\n'
    printf '   Install with: sudo apt install python3-venv\n'
    exit 1
fi
printf 'ℹ  venv module: ok\n'

# ── Source file check ─────────────────────────────────────────
if [ ! -f "$GUI_SRC" ]; then
    printf '❌ Source not found: %s\n' "$GUI_SRC"
    exit 1
fi

# ── Cleanup on exit ───────────────────────────────────────────
cleanup() {
    if [ -d "$VENV" ]; then
        printf '🧹 Removing temporary .venv...\n'
        rm -rf "$VENV"
    fi
}
trap cleanup EXIT

# ── Create venv ───────────────────────────────────────────────
printf '🐍 Creating temporary .venv...\n'
"$PYTHON_BIN" -m venv "$VENV"

PYTHON="$VENV/bin/python3"
PIP="$VENV/bin/pip"

# ── Install dependencies ──────────────────────────────────────
printf '📦 Installing PyInstaller and PyQt6...\n'
"$PIP" install --quiet --upgrade pip
"$PIP" install --quiet pyinstaller PyQt6

# ── Build ─────────────────────────────────────────────────────
printf '🔨 Building GUI (PyInstaller %s)...\n' "$MODE"

WORK_DIR="$SCRIPT_DIR/gui-work"
DIST_DIR="$SCRIPT_DIR/gui-dist"

"$PYTHON" -m PyInstaller \
    "--$MODE" \
    --name "virt-forge" \
    --distpath "$DIST_DIR" \
    --workpath "$WORK_DIR" \
    --specpath "$WORK_DIR" \
    --noconfirm \
    --clean \
    --windowed \
    "$GUI_SRC"

# ── Move output to project root ───────────────────────────────
rm -f  "$ROOT/virt-forge"
rm -rf "$ROOT/_internal"

if [ "$MODE" = "onefile" ]; then
    mv "$DIST_DIR/virt-forge" "$ROOT/virt-forge"
else
    mv "$DIST_DIR/virt-forge/virt-forge"  "$ROOT/virt-forge"
    mv "$DIST_DIR/virt-forge/_internal"   "$ROOT/_internal"
fi

# ── Cleanup PyInstaller temp dirs ─────────────────────────────
rm -rf "$WORK_DIR" "$DIST_DIR"

# ── Done (trap will remove .venv) ─────────────────────────────
printf '✅ GUI built (%s):\n' "$MODE"
if [ "$MODE" = "onefile" ]; then
    printf '     virt-forge   ← single portable binary\n\n'
else
    printf '     virt-forge   ← run this\n'
    printf '     _internal/   ← keep beside the binary\n\n'
fi
